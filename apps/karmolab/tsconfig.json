{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "types": []
  },
  "include": ["src/**/*.ts", "types/**/*.ts", "types/**/*.d.ts"],
  "exclude": ["node_modules"]
}
