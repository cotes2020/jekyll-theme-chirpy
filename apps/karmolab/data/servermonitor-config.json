{
    "localMonitors": [
        {
            "id": "yawnbot-tunnel",
            "title": "YawnBot (dev)",
            "subtitle": "cloudflared + webhook 자동등록 — prod 는 노트북 (TASK-YB-002)",
            "url": "http://127.0.0.1:4615/webhook/github"
        },
        {
            "id": "jekyll",
            "title": "Jekyll Blog",
            "subtitle": "블로그 로컬",
            "url": "http://127.0.0.1:4000/"
        },
        {
            "id": "karmolab-py",
            "title": "KarmoLab 정적 (Python)",
            "subtitle": "/apps/karmolab/",
            "url": "http://127.0.0.1:8002/apps/karmolab/index.html"
        },
        {
            "id": "karmolab-node",
            "title": "KarmoLab 정적 (http-server)",
            "subtitle": "/apps/karmolab/",
            "url": "http://127.0.0.1:8003/apps/karmolab/index.html"
        },
        {
            "id": "karmolab-devmode",
            "title": "KarmoLab Dev",
            "subtitle": "트레이 메뉴에서 켜기",
            "url": "http://127.0.0.1:8899/apps/karmolab/index.html"
        },
        {
            "id": "karmolab-tauri-dev",
            "title": "KarmoLab Tauri Dev",
            "subtitle": "dev:dual — debug 빌드 + 빨간 banner (prod 옆에서 동시)",
            "url": "http://127.0.0.1:8898/apps/karmolab/"
        },
        {
            "id": "karmolab-react",
            "title": "KarmoLab React",
            "subtitle": "Vite dev — TASK-KL-012 stdin 단축키 풀 검증용",
            "url": "http://127.0.0.1:5173/"
        }
    ],
    "envFiles": [
        {
            "id": "yawnbot-env",
            "label": "YawnBot .env (dev)",
            "relPath": "apps/discord-bots/apps/yawnbot/.env",
            "hint": "dev 봇 토큰 + dev 길드. prod 는 GitHub Secrets → 노트북 자동 주입 (TASK-YB-002)"
        },
        {
            "id": "discord-bots-env",
            "label": "discord-bots 공통",
            "relPath": "apps/discord-bots/.env",
            "hint": "워크스페이스 루트(있을 때)"
        }
    ],
    "devProfiles": [
        {
            "id": "jekyll",
            "label": "Jekyll 블로그",
            "cwd": ".",
            "program": "bundle",
            "args": [
                "exec",
                "jekyll",
                "serve",
                "--host",
                "127.0.0.1",
                "--port",
                "4000",
                "--livereload",
                "--incremental"
            ],
            "healthUrl": "http://127.0.0.1:4000/",
            "npmInstall": false
        },
        {
            "id": "yawnbot-tunnel",
            "label": "YawnBot (dev)",
            "cwd": "apps/discord-bots",
            "program": "npm",
            "args": ["run", "dev:yawnbot"],
            "healthUrl": "http://127.0.0.1:4615/webhook/github",
            "npmInstall": true,
            "deployArgs": ["run", "deploy:yawnbot"]
        },
        {
            "id": "karmolab-py",
            "label": "KarmoLab 정적 (Python)",
            "cwd": ".",
            "program": "python",
            "args": ["-m", "http.server", "8002", "--bind", "127.0.0.1"],
            "healthUrl": "http://127.0.0.1:8002/apps/karmolab/index.html",
            "npmInstall": false
        },
        {
            "id": "karmolab-node",
            "label": "KarmoLab 정적 (http-server)",
            "cwd": ".",
            "program": "npx",
            "args": ["--yes", "http-server", ".", "-p", "8003", "-a", "127.0.0.1", "-c-1"],
            "healthUrl": "http://127.0.0.1:8003/apps/karmolab/index.html",
            "npmInstall": false
        },
        {
            "id": "karmolab-tauri-dev",
            "label": "KarmoLab Tauri Dev (dual)",
            "cwd": "apps/karmolab-tauri",
            "program": "npm",
            "args": ["run", "dev:dual"],
            "healthUrl": "http://127.0.0.1:8898/apps/karmolab/",
            "npmInstall": true
        },
        {
            "id": "karmolab-react",
            "label": "KarmoLab React (Vite)",
            "cwd": "apps/karmolab-react-src",
            "program": "npm",
            "args": ["run", "dev"],
            "healthUrl": "http://127.0.0.1:5173/",
            "npmInstall": true
        }
    ]
}
