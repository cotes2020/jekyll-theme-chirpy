        },
        {
            "id": "yawnbot",
            "label": "Discord YawnBot",
            "cwd": "apps/discord-bots",
            "program": "npm",
            "args": ["run", "start:yawnbot"],
            "healthUrl": "http://localhost:8080/webhook/github",
            "npmInstall": true
        }
