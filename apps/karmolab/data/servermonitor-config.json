{
    "localMonitors": [
        {
            "id": "yawnbot",
            "title": "YawnBot",
            "subtitle": "디스코드 봇",
            "url": "http://localhost:8080/webhook/github"
        },
        {
            "id": "jekyll",
            "title": "Jekyll Blog",
            "subtitle": "블로그 로컬",
            "url": "http://127.0.0.1:4000/"
        },
        {
            "id": "atkup",
            "title": "ATKUp",
            "subtitle": "디스코드 봇",
            "noHealthUrl": true
        }
    ],
    "envFiles": [
        {
            "id": "yawnbot-env",
            "label": "YawnBot .env",
            "relPath": "apps/discord-bots/apps/yawnbot/.env",
            "hint": "템플릿: .env.yawnbot.template"
        },
        {
            "id": "atkup-env",
            "label": "ATKUp .env",
            "relPath": "apps/discord-bots/apps/atkup-bot/.env",
            "hint": "템플릿: .env.template"
        },
        {
            "id": "discord-bots-env",
            "label": "discord-bots 공통",
            "relPath": "apps/discord-bots/.env",
            "hint": "워크스페이스 루트(있을 때)"
        }
    ],
    "devProfiles": [
        {
            "id": "jekyll",
            "label": "Jekyll 블로그 (4000)",
            "cwd": ".",
            "program": "bundle",
            "args": [
                "exec",
                "jekyll",
                "serve",
                "--host",
                "127.0.0.1",
                "--port",
                "4000",
                "--livereload",
                "--incremental"
            ],
            "healthUrl": "http://127.0.0.1:4000/",
            "npmInstall": false
        },
        {
            "id": "yawnbot",
            "label": "Discord YawnBot",
            "cwd": "apps/discord-bots",
            "program": "npm",
            "args": ["run", "start:yawnbot"],
            "healthUrl": "http://localhost:8080/webhook/github",
            "npmInstall": true
        },
        {
            "id": "atkup",
            "label": "ATKUp 봇",
            "cwd": "apps/discord-bots",
            "program": "npm",
            "args": ["run", "start:atkup"],
            "npmInstall": true
        }
    ]
}
