{
    "localMonitors": [
        {
            "id": "yawnbot",
            "title": "YawnBot",
            "subtitle": "디스코드 봇",
            "url": "http://127.0.0.1:4615/webhook/github"
        },
        {
            "id": "yawnbot-tunnel",
            "title": "YawnBot + 터널",
            "subtitle": "cloudflared + webhook 자동등록",
            "url": "http://127.0.0.1:4615/webhook/github"
        },
        {
            "id": "jekyll",
            "title": "Jekyll Blog",
            "subtitle": "블로그 로컬",
            "url": "http://127.0.0.1:4000/"
        },
        {
            "id": "atkup",
            "title": "ATKUp",
            "subtitle": "디스코드 봇",
            "url": "http://127.0.0.1:4616/health"
        },
        {
            "id": "karmolab-py",
            "title": "KarmoLab 정적 (Python)",
            "subtitle": "/apps/karmolab/",
            "url": "http://127.0.0.1:8002/apps/karmolab/index.html"
        },
        {
            "id": "karmolab-node",
            "title": "KarmoLab 정적 (http-server)",
            "subtitle": "/apps/karmolab/",
            "url": "http://127.0.0.1:8003/apps/karmolab/index.html"
        },
        {
            "id": "karmolab-devmode",
            "title": "KarmoLab Dev (트레이 토글)",
            "subtitle": "트레이 메뉴에서 켜기",
            "url": "http://127.0.0.1:8899/apps/karmolab/index.html"
        }
    ],
    "envFiles": [
        {
            "id": "yawnbot-env",
            "label": "YawnBot .env",
            "relPath": "apps/discord-bots/apps/yawnbot/.env",
            "hint": "템플릿: .env.yawnbot.template"
        },
        {
            "id": "atkup-env",
            "label": "ATKUp .env",
            "relPath": "apps/discord-bots/apps/atkup-bot/.env",
            "hint": "템플릿: .env.template"
        },
        {
            "id": "discord-bots-env",
            "label": "discord-bots 공통",
            "relPath": "apps/discord-bots/.env",
            "hint": "워크스페이스 루트(있을 때)"
        }
    ],
    "devProfiles": [
        {
            "id": "jekyll",
            "label": "Jekyll 블로그",
            "cwd": ".",
            "program": "bundle",
            "args": [
                "exec",
                "jekyll",
                "serve",
                "--host",
                "127.0.0.1",
                "--port",
                "4000",
                "--livereload",
                "--incremental"
            ],
            "healthUrl": "http://127.0.0.1:4000/",
            "npmInstall": false
        },
        {
            "id": "yawnbot",
            "label": "Discord YawnBot",
            "cwd": "apps/discord-bots",
            "program": "npm",
            "args": ["run", "start:yawnbot"],
            "healthUrl": "http://127.0.0.1:4615/webhook/github",
            "npmInstall": true,
            "deployArgs": ["run", "deploy:yawnbot"]
        },
        {
            "id": "yawnbot-tunnel",
            "label": "YawnBot + cloudflared 터널 (webhook 자동등록)",
            "cwd": "apps/discord-bots/apps/yawnbot",
            "program": "npm",
            "args": ["run", "dev"],
            "healthUrl": "http://127.0.0.1:4615/webhook/github",
            "npmInstall": false
        },
        {
            "id": "atkup",
            "label": "ATKUp 봇",
            "cwd": "apps/discord-bots",
            "program": "npm",
            "args": ["run", "start:atkup"],
            "healthUrl": "http://127.0.0.1:4616/health",
            "npmInstall": true,
            "deployArgs": ["run", "deploy:atkup"]
        },
        {
            "id": "karmolab-py",
            "label": "KarmoLab 정적 (Python)",
            "cwd": ".",
            "program": "python",
            "args": ["-m", "http.server", "8002", "--bind", "127.0.0.1"],
            "healthUrl": "http://127.0.0.1:8002/apps/karmolab/index.html",
            "npmInstall": false
        },
        {
            "id": "karmolab-node",
            "label": "KarmoLab 정적 (http-server)",
            "cwd": ".",
            "program": "npx",
            "args": ["--yes", "http-server", ".", "-p", "8003", "-a", "127.0.0.1", "-c-1"],
            "healthUrl": "http://127.0.0.1:8003/apps/karmolab/index.html",
            "npmInstall": false
        }
    ]
}
