{
  "name": "karmolab-js",
  "private": true,
  "version": "1.0.0",
  "description": "KarmoLab TypeScript sources; build emits to js/ for Jekyll/GitHub Pages",
  "type": "module",
  "dependencies": {
    "karmolab-ai": "file:../../packages/karmolab-ai"
  },
  "scripts": {
    "build:wiki": "node scripts/sync-wiki.mjs",
    "build": "npm run build:wiki && node build.mjs",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "~5.9.0"
  }
}
