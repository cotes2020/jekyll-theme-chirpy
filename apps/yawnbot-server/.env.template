# YawnBot Environment Variables Template
# 이 파일을 .env로 복사한 뒤 실제 값을 채워넣으세요.

# Discord Bot Token
# 🔗 발급처: https://discord.com/developers/applications
# 사용 중인 봇 애플리케이션 선택 -> 왼쪽 메뉴의 'Bot' 탭 -> 'Token' 복사 (또는 Reset Token)
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# Discord Application (Client) ID
# 🔗 발급처: https://discord.com/developers/applications
# 사용 중인 봇 애플리케이션 선택 -> 왼쪽 메뉴의 'OAuth2' 탭 -> 'Client ID' 복사
CLIENT_ID=YOUR_CLIENT_ID_HERE

# Discord Channel ID for GitHub Webhook Notifications
# 🔗 발급처: 디스코드 앱 실행 -> 설정 -> 고급 -> '개발자 모드' 켜기
# 알림을 띄울 채널 우클릭 -> '채널 ID 복사'
GITHUB_WEBHOOK_CHANNEL_ID=YOUR_CHANNEL_ID_HERE

# Gemini API Key (Optional)
# 🔗 발급처: https://aistudio.google.com/app/apikey
# Google AI Studio 접속 -> 'Create API Key' 클릭
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.0-flash

# Admin User IDs (comma-separated)
ADMIN_IDS=391805564616704002
