# =============================================================================
# chat-overlay 환경 변수 템플릿
# -----------------------------------------------------------------------------
# 사용: 이 파일을 복사해 `apps/chat-overlay/.env` 로 저장한 뒤 값을 채웁니다.
#   PowerShell:  Copy-Item .env.example .env
#   bash:        cp .env.example .env
# `.env` 는 git에 올리지 마세요(비밀 포함). 이 `.env.example` 만 커밋합니다.
# =============================================================================

# -----------------------------------------------------------------------------
# VITE_CHAT_FEED
# -----------------------------------------------------------------------------
# 의미: 어떤 채팅 소스를 쓸지 고릅니다.
# 허용 값:
#   random — 데모용 가짜 채팅 (기본과 동일)
#   chzzk  — 치지직 연동(아래 CHZZK_* 와 함께 사용)
#   extension — 브라우저 확장(KarmoWebExtension)만: `POST http://127.0.0.1:17376/ingest`
# 참고(코드): `src/chat/createChatFeed.ts` 의 `chatFeedKindFromEnv()`
# -----------------------------------------------------------------------------
VITE_CHAT_FEED=extension

# -----------------------------------------------------------------------------
# VITE_CHZZK_SESSION
# -----------------------------------------------------------------------------
# 의미: `1` 이면 공식 Session API + Socket.IO 로 실시간 채팅 수신을 시도합니다.
#       비우거나 `1` 이 아니면 토큰이 있어도 안내 메시지 전용 피드로 동작합니다.
# 필요 조건: 유저 OAuth Access Token + API Scope `채팅 메시지 조회`
# 문서(Session·구독·소켓): https://chzzk.gitbook.io/chzzk/chzzk-api/session
# -----------------------------------------------------------------------------
VITE_CHZZK_SESSION=1

# -----------------------------------------------------------------------------
# VITE_CHZZK_ACCESS_TOKEN
# -----------------------------------------------------------------------------
# 의미: 치지직 Open API 호출에 쓰는 **유저 Access Token** (Authorization: Bearer).
# 어디서 받나:
#   1) 개발자 센터에서 앱 등록 → Client ID / Secret 발급
#      https://developers.chzzk.naver.com/
#   2) 인증 코드 요청 URL (브라우저 로그인 후 code 수신)
#      https://chzzk.gitbook.io/chzzk/chzzk-api/authorization
#      엔드포인트: GET https://chzzk.naver.com/account-interlock?clientId=...&redirectUri=...&state=...
#   3) code 로 Access Token 발급
#      POST https://openapi.chzzk.naver.com/auth/v1/token
#      (grantType=authorization_code, clientId, clientSecret, code, state)
#      상세: https://chzzk.gitbook.io/chzzk/chzzk-api/authorization
# 앱 등록 시 API Scope 에 **채팅 메시지 조회** 포함(Session 문서의 채팅 구독에 필요).
# 채널 선택: Session API는 채널 ID를 넘겨 고르지 않습니다. 토큰을 발급한 **그 치지직
# 계정(방송자)** 의 채팅 이벤트만 오며, **그 계정이 방송 중**일 때 시청자 채팅이 옵니다.
# 주의: `VITE_` 접두사 변수는 프론트 번들에 포함될 수 있습니다. 배포용은 Tauri 등에서
#       안전하게 주입하는 방식을 권장합니다.
# 문서(API 도메인·Bearer 형식): https://chzzk.gitbook.io/chzzk/chzzk-api/tips
# -----------------------------------------------------------------------------
VITE_CHZZK_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# VITE_CHZZK_OPENAPI_BASE (선택)
# -----------------------------------------------------------------------------
# 비우면: `npm run dev` 에서는 Vite가 `/__chzzk_openapi` 로 프록시(브라우저 CORS 회피).
#         `vite build` 결과를 정적 호스팅만 할 때는 직접 openapi 도메인 호출 → CORS로
#         "Failed to fetch" 가 날 수 있음. 그 경우 역프록시 경로를 여기에 맞춰 주거나
#         Tauri 등 네이티브에서 실행하세요.
# -----------------------------------------------------------------------------
# VITE_CHZZK_OPENAPI_BASE=
