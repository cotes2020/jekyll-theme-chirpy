{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "KarmoLab webview (embedded _site or remote): invoke desktop_notify; main window.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://mascari4615.github.io/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "permissions": [
    "core:default",
    "allow-desktop-notify",
    "allow-localdev",
    "allow-repofile",
    "updater:default"
  ]
}
