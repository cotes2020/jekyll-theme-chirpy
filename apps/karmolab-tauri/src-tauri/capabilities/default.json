{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "KarmoLab webview (embedded _site or remote): invoke desktop_notify; main window.",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://mascari4615.github.io/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:allow-listen",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-start-dragging",
    "core:window:allow-is-maximized",
    "allow-desktop-notify",
    "allow-localdev",
    "allow-repofile",
    "allow-karmolab-update",
    "allow-karmolab-release",
    "allow-activity",
    "allow-karmoddrine-state",
    "allow-quest-index",
    "allow-flow-doc",
    "updater:default"
  ]
}
