{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KarmoLab",
  "version": "0.1.0",
  "identifier": "com.mascari4615.karmolab",
  "build": {
    "devUrl": "https://mascari4615.github.io/karmolab/",
    "frontendDist": "https://mascari4615.github.io/karmolab/"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "KarmoLab",
        "width": 1100,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
