{
  "name": "karmolab-desktop",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "concurrently -n static,tauri \"npm run dev:static\" \"npm run dev:tauri\"",
    "dev:static": "node ./scripts/dev-static.mjs",
    "dev:tauri": "wait-on http-get://127.0.0.1:8899/apps/karmolab/ -t 120000 -i 250 && tauri dev",
    "dev:jekyll": "cd ../.. && bundle exec jekyll serve --host 127.0.0.1 --port 4000 --livereload --incremental --force_polling",
    "dev:tauri:jekyll": "wait-on http-get://127.0.0.1:4000/karmolab/ -t 600000 -i 500 && tauri dev --config src-tauri/tauri.dev-jekyll.conf.json",
    "dev:with-jekyll": "concurrently -n jekyll,tauri \"npm run dev:jekyll\" \"npm run dev:tauri:jekyll\"",
    "dev:app": "tauri dev",
    "dev:remote": "tauri dev --config src-tauri/tauri.dev-remote.conf.json",
    "build": "tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "concurrently": "^9.1.2",
    "wait-on": "^8.0.1"
  }
}
