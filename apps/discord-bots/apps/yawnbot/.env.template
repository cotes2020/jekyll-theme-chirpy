# 욘 (패키지 폴더명 yawnbot) — 환경 변수 템플릿
# 이 파일을 .env로 복사한 뒤 실제 값을 채워넣으세요.

# Discord Bot Token
# 🔗 발급처: https://discord.com/developers/applications
# 사용 중인 봇 애플리케이션 선택 -> 왼쪽 메뉴의 'Bot' 탭 -> 'Token' 복사 (또는 Reset Token)
DISCORD_TOKEN=YOUR_BOT_TOKEN_HERE

# Discord Application (Client) ID
# 🔗 발급처: https://discord.com/developers/applications
# 사용 중인 봇 애플리케이션 선택 -> 왼쪽 메뉴의 'OAuth2' 탭 -> 'Client ID' 복사
CLIENT_ID=YOUR_CLIENT_ID_HERE

# (선택) deploy 시 전역 등록 + 나열한 길드에도 등록(해당 서버는 보통 수 초 안에 반영). 여러 개는 쉼표로: id1,id2
DISCORD_GUILD_ID=

# ── 음성·미디어 (/play, /speak, /sound) ──
# 음악(/play): npm 패키지 ffmpeg-static으로 내장 FFmpeg 경로를 씁니다. 여전히 무음이면 서버에서 봇이 음소거·mute 아닌지 확인하세요.
# YouTube: yt-dlp 바이너리·쿠키 (선택)
# YT_DLP_PATH=
# YT_DLP_COOKIES_PATH=

# /speak (Edge TTS, node-edge-tts) — 보이스 목록: https://learn.microsoft.com/azure/ai-services/speech-service/language-support?tabs=tts
# SPEAK_VOICE=ko-KR-SunHiNeural
# SPEAK_LANG=ko-KR
# SPEAK_TTS_PROXY=
# SPEAK_TTS_TIMEOUT_MS=30000

# 음성 디버그: join 시 상세 로그(민감 정보 포함 가능 — 필요할 때만)
# VOICE_DEBUG=1
# DAVE(E2EE) — E2EE 필수 채널에서 음성 close 4017이면 켜야 함. 잘 되면 계속 1 유지해도 됨.
# DISCORD_VOICE_DAVE=1

# GitHub 웹훅 알림을 보낼 텍스트 채널 ID. 여러 채널은 쉼표로: id1,id2
# 🔗 채널 우클릭 -> 채널 ID 복사 (개발자 모드)
GITHUB_WEBHOOK_CHANNEL_ID=YOUR_CHANNEL_ID_HERE

# Gemini API Key (Optional)
# 🔗 발급처: https://aistudio.google.com/app/apikey
# Google AI Studio 접속 -> 'Create API Key' 클릭
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# ── Kakao PC export → 요약 → Discord (개인용, scripts/kakao-export.mjs) ──
# npm run kakao-export — 저장 후 곧바로 요약
# npm run kakao-export-save — 저장만 (제미니·웹훅 없이 테스트)
# npm run kakao-export -- --scan / --watch (필요 시)
# 상시 감시: kakao-export-watch-bg + kakao-export-watch-stop
# KAKAO_EXPORT_MAX_ROUNDS=80
# 메인 창 제목과 정확히 같으면 건너뜀 (기본 카카오톡|KakaoTalk). 스킵 끄기: KAKAO_EXPORT_SKIP_WINDOW_TITLES=OFF
# KAKAO_EXPORT_SAVE_WAIT_TIMEOUT_SEC=90
# KAKAO_EXPORT_SAVE_POLL_MS=200
# KAKAO_EXPORT_FILE_STABLE_CHECKS=3
# KAKAO_EXPORT_AFTER_FILE_MS=400
# KAKAO_EXPORT_BETWEEN_CHATS_MS=500
# KAKAO_EXPORT_WATCH_DIR=%USERPROFILE%\Documents\카카오톡 받은 파일
# (기본값이 위와 동일. 다른 폴더면 이 줄만 수정 — 트리거·감시 경로가 같아야 함)
# 채널 설정 → 연동 서비스 → 웹후크 → Incoming Webhook URL
# DISCORD_SUMMARY_WEBHOOK_URL=https://discord.com/api/webhooks/...

# 관리자 Discord 유저 ID. 여러 명은 쉼표로: id1,id2
ADMIN_IDS=391805564616704002

# ── Cursor 로컬 에이전트 (Discord /cursor-edit → cli/cursor-local-runner.js) ──
# (선택) Cursor가 수정할 로컬 git 폴더. 비우면: yawnbot이 들어 있는 이 github.io 레포 루트를 자동 사용
# (클론 위치·드라이브 문자와 무관). 다른 저장소만 건드리려면 여기에 그 폴더 절대 경로를 적습니다.
CURSOR_LOCAL_REPO_DIR=

# Cursor CLI 바이너리 이름 또는 전체 경로 (PATH에 있으면 agent)
CURSOR_AGENT_COMMAND=agent

# 에이전트 전체 타임아웃(ms). 기본 600000 (10분)
CURSOR_TIMEOUT_MS=600000

# (선택) 마지막 스트림 청크 후 이 ms 동안 session/prompt JSON-RPC가 없으면 완료로 간주. 기본 120000(2분).
# 매우 긴 추론(청크 없이 2분 이상)이면 늘리거나 0으로 끄고 stderr 로그로 원인 확인.
CURSOR_PROMPT_IDLE_MS=120000

# cursor/ask_question: 부모(봇)가 stdin 한 줄을 안 보낼 때(버그·상호작용 실패) 대기 상한(ms). 기본 600000(10분). 0=무제한
CURSOR_QUESTION_STDIN_MS=600000

# 봇이 자식 러너(node cli/...)를 강제 종료하기 전 추가 여유(ms). 기본 120000 (2분)
CURSOR_RUNNER_GRACE_MS=120000

# defer 후 경과 시간 표시 갱신 주기(ms). 너무 짧으면 Discord rate limit에 걸릴 수 있음. 기본 2500
DEFER_TICK_MS=2500

# editReply만 쓰면 알림이 거의 안 올 수 있음 → 완료 시 followUp(새 메시지)로 안내
# off | ephemeral(명령 실행자만 보임) | mention(채널에 멘션, 알림이 가장 잘 옴)
DEFER_COMPLETION_NOTIFY=ephemeral

# 디스코드 프롬프트·CLI --prompt 최대 길이
CURSOR_MAX_PROMPT_CHARS=2000

# git diff 미리보기 최대 길이 (runner stdout JSON에 포함)
CURSOR_DIFF_PREVIEW_CHARS=8000

# git 스냅샷 (작업 트리는 그대로, 러너가 `git stash create -u` baseline만 잡고 diff는 baseline 대비)
# baseline | off (stash는 예전 이름 호환용이며 push/pop은 하지 않음)
CURSOR_GIT_SNAPSHOT=baseline

# cursor/ask_question: 봇이 러너 stdin에 연결되면 디스코드에서 선택(미설정=대화형). 0=항상 자동(첫 옵션)
CURSOR_INTERACTIVE_QUESTIONS=1