{
  "name": "yawnbot",
  "private": true,
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "deploy": "node dist/src/deploy-commands.js",
    "dev": "npm run build && concurrently -k \"tsc -w --preserveWatchOutput\" \"nodemon -q -w dist -e js -d 1.5 dist/src/main.js\""
  },
  "dependencies": {
    "@discord-bots/common": "*",
    "@discordjs/voice": "^0.18.0",
    "@google/generative-ai": "^0.21.0",
    "discord.js": "^14.26.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "libsodium-wrappers": "^0.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "typescript": "^6.0.2"
  }
}
