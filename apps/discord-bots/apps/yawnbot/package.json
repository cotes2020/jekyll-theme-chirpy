{
  "name": "yawnbot",
  "private": true,
  "main": "dist/src/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "deploy": "node dist/src/deploy-commands.js",
    "deploy:clear-global": "node scripts/clear-global-commands.mjs",
    "dev": "tsc-watch -p tsconfig.json --preserveWatchOutput --onSuccess \"node dist/src/main.js\"",
    "kakao-export": "node scripts/kakao-export.mjs",
    "kakao-export-save": "node scripts/kakao-export.mjs --trigger-only",
    "kakao-export-watch": "node scripts/kakao-export.mjs --watch",
    "kakao-export-watch-bg": "node scripts/kakao-export-watch-background.mjs",
    "kakao-export-watch-stop": "node scripts/kakao-export-watch-stop.mjs"
  },
  "dependencies": {
    "karmolab-ai": "file:../../../../packages/karmolab-ai",
    "@discord-bots/common": "*",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.2",
    "@google/generative-ai": "^0.21.0",
    "discord.js": "^14.26.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "ffmpeg-static": "^5.3.0",
    "libsodium-wrappers": "^0.8.2",
    "node-edge-tts": "^1.2.10",
    "opusscript": "^0.0.8",
    "play-dl": "^1.9.7",
    "youtube-dl-exec": "^3.1.4",
    "youtubei.js": "^17.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsc-watch": "^7.2.0",
    "typescript": "^6.0.2"
  }
}
