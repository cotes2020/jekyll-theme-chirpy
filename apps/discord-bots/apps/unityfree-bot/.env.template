# UnityFree Bot Environment Variables Template
# 이 파일을 .env로 복사한 뒤 실제 값을 채워넣으세요.

# Unity 무료 에셋 전용 디스코드 봇 토큰 (필수)
UNITYFREE_DISCORD_TOKEN=YOUR_UNITYFREE_BOT_TOKEN_HERE

# Unity 무료 에셋 봇 애플리케이션(Client) ID (슬래시 커맨드 배포용, 필수)
UNITYFREE_CLIENT_ID=YOUR_UNITYFREE_CLIENT_ID_HERE

# 무료 에셋 알림을 보낼 채널 ID (필수)
UNITYFREE_TARGET_CHANNEL_ID=YOUR_UNITYFREE_CHANNEL_ID_HERE

# Unity 무료 에셋 페이지 체크 주기 (분 단위, 기본 60)
UNITYFREE_CHECK_INTERVAL_MIN=60

