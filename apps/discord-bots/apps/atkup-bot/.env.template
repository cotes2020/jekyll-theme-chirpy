# ATKUp 봇 — 환경 변수 템플릿 (`apps/discord-bots/apps/atkup-bot`)
# 이 파일을 .env로 복사한 뒤 실제 값을 채워넣으세요.

# ATKUp 전용 디스코드 봇 토큰 (필수)
ATKUP_DISCORD_TOKEN=YOUR_ATKUP_BOT_TOKEN_HERE

# ATKUp 봇 애플리케이션(Client) ID (슬래시 커맨드 배포용, 필수)
ATKUP_CLIENT_ID=YOUR_ATKUP_CLIENT_ID_HERE

# 알림을 보낼 채널 ID (필수)
ATKUP_TARGET_CHANNEL_ID=YOUR_ATKUP_CHANNEL_ID_HERE

# Unity Publisher Sale 페이지 체크 주기 (분 단위, 기본 60)
ATKUP_CHECK_INTERVAL_MIN=60
