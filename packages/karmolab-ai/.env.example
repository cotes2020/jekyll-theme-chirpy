# KarmoLab AI — 공통 AI 자격증명
# 이 파일을 .env 로 복사하고 값을 채우세요.
# .env 는 .gitignore 로 보호됩니다 (커밋 금지).

# ── 서피스 선택 ──
# vertex 또는 aiStudio (기본). Vertex 크레딧이 있으면 vertex 권장.
KARMOLAB_AI_SURFACE=vertex

# ── AI Studio (Gemini API 키) ──
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Vertex AI ──
# https://cloud.google.com/vertex-ai/generative-ai/docs/start/api-keys
VERTEX_API_KEY=
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-central1
